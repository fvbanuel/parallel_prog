
# --- Compiled Binaries & Objects ---
*.o
*.obj
*.so
*.dylib
*.dll
*.exe
*.out
*.app

# --- CUDA Specific Intermediate Files ---
# These are generated during the NVCC compilation process
*.ptx
*.cubin
*.fatbin
*.gpu
*.ii

# --- Build Systems (CMake/Make) ---
[Bb]uild/
CMakeFiles/
CMakeCache.txt
CMakeScripts/
cmake_install.cmake
Makefile
install_manifest.txt

# --- IDE & Editor Configs ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# --- Python (if using PyCUDA or PyMPI) ---
__pycache__/
*.py[cod]
*$py.class
